{
  "name": "moviematcherv2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "dev:netlify": "netlify dev --filter web -p 8888",
    "build": "npm run build --workspace apps/web",
    "test": "npm run test --workspace apps/web",
    "typecheck:functions": "tsc -p apps/functions/tsconfig.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "simulate:room": "RUN_MULTI_USER_SIM=1 playwright test tests/e2e/multi-user-simulator.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/jest": "^30.0.0",
    "jest-dom": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
